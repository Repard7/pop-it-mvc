{
    "name": "repard7/pop-it-mvc",
    "description": "simple mvc app-",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Ростислав Грачев",
            "email": "gracevrostislav5@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "repositories": [
        {
            "type": "path",
            "url": "packages/collect"
        },
        {
            "type": "path",
            "url": "packages/validation"
        }
    ],
    "require": {
        "php": "^7.4 | ^8.0",
        "illuminate/database": "^12.0@dev",
        "illuminate/events": "^12.0@dev",
        "nikic/fast-route": "^2.0@dev",
        "repard7/collect": "@dev",
        "repard7/validation": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Src\\": "core/src/",
            "": "app/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "config": {
        "audit": {
            "block-insecure": false
        }
    }
}
